# Non-secret, per-cluster settings for this operator instance. Edit these
# before `make deploy` for a given cluster — see docs/production-deploy.md.
# ENROLLMENT_SECRET does NOT go here; it's created out-of-band as a Secret
# named ai-cloud-operator-env, never committed, and mounted as a volume (see
# config/manager/manager.yaml), not passed as an env var. GATEWAY_SIGNING_SECRET
# isn't set anywhere at all — the operator generates and persists its own on
# first boot (see internal/gateway.KeyStore).

# The base URL of your self-hosted (or cloud) Convex deployment, e.g.
# https://backend-xxxxx.example.com — no trailing slash.
CONVEX_BASE_URL=

# A short, stable name identifying this operator instance to Convex (shows
# up in the operators list/UI). Must be unique per Convex deployment.
OPERATOR_NAME=

# The public HTTPS URL this operator will be reachable at once the Service
# (and, if used, the config/ingress overlay) are wired up for this cluster —
# what Convex calls back into for deploy/delete/catalog/gateway-verify, and
# what browsers use for /gw/* gateway routes.
OPERATOR_EXTERNAL_URL=

# The single Kubernetes namespace every workload this operator manages gets
# deployed into — an install-time decision for this operator instance, not
# something Convex chooses or sends per-request. Created automatically on
# first boot if it doesn't already exist (see internal/workloadns). Unlike
# the vars above, this ships with a real default — change it before
# `make deploy` only if you want workloads somewhere other than this.
WORKLOAD_NAMESPACE=ai-cloud-workloads

# How often the operator heartbeats Convex (Go duration format, e.g. "30s",
# "15s", "1m"). This is also the claim-discovery cadence for create/destroy/
# redeploy/stop/resume requests (see cmd/main.go), so it's a direct latency
# knob: a user action can take up to one full interval to be picked up.
# Ships with a real default — change it before `make deploy` only if you
# want a different cadence for this cluster.
HEARTBEAT_INTERVAL=30s

# How often the operator collects and reports per-workload usage metrics
# (network bytes in/out today — see internal/metrics) to Convex, via its own
# POST /operators/metrics/report call, deliberately segregated from and much
# coarser than HEARTBEAT_INTERVAL above — this is telemetry for a dashboard
# chart, not anything latency-sensitive. Ships with a real default — change
# it before `make deploy` only if you want a different cadence for this
# cluster.
METRICS_REPORT_INTERVAL=5m
